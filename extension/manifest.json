{
  "manifest_version": 3,
  "name": "Кактус загрузка",
  "version": "1.4.1",
  "description": "Скачивай видео с YouTube, VK, TikTok, Pinterest и других соцсетей",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Кактус загрузка",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["activeTab", "cookies", "downloads", "storage"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://*.onrender.com/*",
    "https://*.youtube.com/*",
    "https://youtube.com/*",
    "https://*.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1:8081/*",
        "http://localhost:8081/*",
        "https://*.onrender.com/*",
        "https://kaktus-zagruzka.onrender.com/*"
      ],
      "js": ["cookies-util.js", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://youtube.com/*"
      ],
      "js": ["cookies-util.js", "youtube-sync.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
