{
  "manifest_version": 3,
  "name": "Кактус загрузка",
  "version": "1.0.0",
  "description": "Скачивай видео с YouTube, VK, TikTok, Pinterest и других соцсетей",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Кактус загрузка",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["activeTab", "downloads", "storage"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://*.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
